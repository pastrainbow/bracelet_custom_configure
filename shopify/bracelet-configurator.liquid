{%- comment -%}
  Bracelet Configurator — full-bleed section.

  Fills the whole viewport below the header and hides the theme footer on this
  page only (a {% style %} block is emitted just for pages containing this
  section, so other pages keep their footer).

  Assets uploaded by `npm run deploy:shopify`:
    - bracelet-configurator.umd.js
    - bracelet-configurator.css
{%- endcomment -%}

<div id="bracelet-configurator"></div>

{%- comment -%}
  Catalogue feed. Every product in the "Bracelet Configurator Items" smart
  collection (condition: tag = `configurator`) is emitted as JSON that the widget
  reads on mount (see readInjectedCatalogue in mount.tsx). Bead prices are
  per-size, taken from each "<mm> mm" variant's own price; accessories use the
  product price. Category and
  super-category ride along as tags (`cat:<slug>`, `super:beads|accessories`), and
  each sprite is a theme asset named `sprite-<handle>.png` pushed by the deploy
  script — so no product metafields are required.

  Note: `collection.products` returns up to 50 items without pagination; add a
  {% paginate %} loop (or move to the Storefront API) if the catalogue grows past that.
{%- endcomment -%}
<script id="bracelet-catalogue" type="application/json">
{%- assign cfg = collections['bracelet-configurator-items'] -%}
{"items":[
{%- for p in cfg.products -%}
  {%- assign superCat = '' -%}
  {%- assign catSlug = '' -%}
  {%- for t in p.tags -%}
    {%- if t contains 'super:' -%}{%- assign superCat = t | remove_first: 'super:' | strip -%}{%- endif -%}
    {%- if t contains 'cat:' -%}{%- assign catSlug = t | remove_first: 'cat:' | strip -%}{%- endif -%}
  {%- endfor -%}
  {"id":{{ p.handle | json }},"name":{{ p.title | json }},"price":{{ p.price | divided_by: 100.0 }},"prices":{
    {%- comment -%} Per-size bead prices: one entry per "<mm> mm" variant, from that variant's own price. Empty for one-size accessories (they use "price"). {%- endcomment -%}
    {%- assign firstPrice = true -%}
    {%- for v in p.variants -%}
      {%- assign mm = v.option1 | remove: ' mm' | remove: 'mm' | strip -%}
      {%- if mm != '' and mm != 'One Size' -%}{%- unless firstPrice -%},{%- endunless -%}"{{ mm | times: 1 }}":{{ v.price | divided_by: 100.0 }}{%- assign firstPrice = false -%}{%- endif -%}
    {%- endfor -%}
  },"variantId":{{ p.variants.first.id }},"variantIds":{
    {%- comment -%} Per-size variant ids, mirroring "prices". Add-to-cart posts these real variants so the cart total equals the widget total. "variantId" (first variant) covers one-size accessories. {%- endcomment -%}
    {%- assign firstVid = true -%}
    {%- for v in p.variants -%}
      {%- assign mm = v.option1 | remove: ' mm' | remove: 'mm' | strip -%}
      {%- if mm != '' and mm != 'One Size' -%}{%- unless firstVid -%},{%- endunless -%}"{{ mm | times: 1 }}":{{ v.id }}{%- assign firstVid = false -%}{%- endif -%}
    {%- endfor -%}
  },"superCategory":{{ superCat | json }},"category":{{ catSlug | json }},"imageUrl":{{ 'sprite-' | append: p.handle | append: '.png' | asset_url | json }},"sizes":[
    {%- assign firstSize = true -%}
    {%- for v in p.variants -%}
      {%- assign mm = v.option1 | remove: ' mm' | remove: 'mm' | strip -%}
      {%- if mm != '' and mm != 'One Size' -%}{%- unless firstSize -%},{%- endunless -%}{{ mm | times: 1 }}{%- assign firstSize = false -%}{%- endif -%}
    {%- endfor -%}
  ]}{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]}
</script>

{{ 'bracelet-configurator.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* Full-bleed: no section spacing, edge to edge. */
  #shopify-section-{{ section.id }} {
    margin: 0;
    padding: 0;
  }
  #bracelet-configurator {
    width: 100%;
    min-height: 560px; /* JS sets the exact viewport-minus-header height */
  }
  /* Hide the footer + newsletter on THIS page only. */
  .shopify-section-group-footer-group,
  .footer,
  footer.footer {
    display: none !important;
  }
{%- endstyle -%}

<script src="{{ 'bracelet-configurator.umd.js' | asset_url }}" defer></script>
<script>
  (function () {
    var SELECTOR = '#bracelet-configurator';

    // Size the configurator to fill the space below whatever sits above it
    // (header + announcement bar), without needing to know the header's height.
    function fit() {
      var el = document.querySelector(SELECTOR);
      if (!el) return;
      var top = el.getBoundingClientRect().top; // distance from top at scroll 0
      el.style.height = Math.max(560, window.innerHeight - top) + 'px';
    }

    // Shown if the widget bundle failed to load or crashed while mounting —
    // otherwise the section is just silently blank.
    function showLoadFailure(el) {
      el.innerHTML =
        '<p style="padding:48px 24px;text-align:center;font-size:14px;color:#6b6b6b;">' +
        'The bracelet builder could not load. Please refresh the page.' +
        '</p>';
    }

    function init() {
      if (!window.BraceletConfigurator) return;
      var el = document.querySelector(SELECTOR);
      if (!el || el.dataset.mounted) return; // don't double-mount
      el.dataset.mounted = '1';
      fit();

      try {
        window.BraceletConfigurator.mount(el, {
          wristHint: 'Wrist size: 15.5 – 16.5 cm',
          onAddToCart: function (payload) {
            // The design is priced by adding each component's real Shopify
            // variant (payload.lines: one line per distinct variant, with
            // quantity), so the cart total is exactly the widget's total and
            // stock is drawn from the right variants. A shared, unique
            // '_bracelet_id' property marks the lines as one bracelet: the
            // customised cart section (sections/main-cart-items.liquid)
            // collapses them into a single "Custom Bracelet" row whose image
            // is the '_thumb' render, and the unique id keeps two designs —
            // even identical ones — from merging. Underscore-prefixed
            // properties stay hidden from the shopper but ride along to the
            // order for fulfilment ('_design' is the exact design code).
            var missing = payload.lines.filter(function (l) { return !l.variantId; });
            if (missing.length) {
              return Promise.reject(new Error(
                'These items cannot be ordered right now: ' +
                missing.map(function (l) { return l.name; }).join(', ') +
                '. Please remove them or try again later.'
              ));
            }
            var braceletId = 'b' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 8);
            var properties = {
              'Bracelet': payload.beadCount + ' beads, ~' + payload.estimatedLengthCm + ' cm',
              '_design': payload.designCode,
              '_bracelet_id': braceletId
            };
            if (payload.wristSizeCm) {
              properties['Wrist size'] = payload.wristSizeCm + ' cm';
            }
            function postAdd(includeThumb) {
              return fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  items: payload.lines.map(function (l, i) {
                    // The bracelet render rides on the first line only (it's
                    // ~10–25 KB; no point duplicating it on every line).
                    var props = properties;
                    if (includeThumb && i === 0 && payload.previewImage) {
                      props = Object.assign({ '_thumb': payload.previewImage }, properties);
                    }
                    return { id: l.variantId, quantity: l.quantity, properties: props };
                  })
                })
              });
            }
            return postAdd(true).then(function (r) {
              if (!r.ok && payload.previewImage) {
                // The thumbnail may have pushed the request over a size limit.
                // A failed multi-item add adds nothing, so retrying without it
                // can't double-add; the cart row falls back to a bead image.
                return postAdd(false);
              }
              return r;
            }).then(function (r) {
              if (!r.ok) {
                // Shopify's cart error body carries a shopper-readable
                // `description` (e.g. sold out); rethrow it so the widget's
                // error toast shows it instead of redirecting anyway.
                return r.json().catch(function () { return {}; }).then(function (data) {
                  throw new Error(data.description || data.message || 'Could not add to cart — please try again.');
                });
              }
              window.location.href = '/cart';
            });
          }
        });
      } catch (err) {
        console.error('[BraceletConfigurator] mount failed', err);
        showLoadFailure(el);
      }
    }

    window.addEventListener('resize', fit);
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('shopify:section:load', init); // theme editor re-render
    window.addEventListener('load', init);
    window.addEventListener('load', function () {
      // Past window.load the deferred bundle has run (or failed); if nothing
      // mounted by now the script didn't load — tell the shopper.
      var el = document.querySelector(SELECTOR);
      if (el && !el.dataset.mounted) showLoadFailure(el);
    });
  })();
</script>

{% schema %}
{
  "name": "Bracelet Configurator",
  "settings": [],
  "presets": [{ "name": "Bracelet Configurator" }]
}
{% endschema %}
