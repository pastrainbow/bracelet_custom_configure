# Shopify credentials. Copy this file to `.env` (which is gitignored) and
# fill in the values.
#
# ── Widget deploy (`npm run deploy:shopify`) ─────────────────────────────────
# Uses the Shopify CLI with a Theme Access token:
#   1. Install the free "Theme Access" app: https://apps.shopify.com/theme-access
#   2. In it, add a user with your email — Shopify emails you a token (shptka_...)
#   3. Paste that token below as SHOPIFY_ADMIN_TOKEN.
#
# Find SHOPIFY_THEME_ID in the theme editor URL:
#   admin.shopify.com/store/<store>/themes/<THEME_ID>/editor

SHOPIFY_STORE=y4i4ta-hn.myshopify.com
SHOPIFY_ADMIN_TOKEN=shptka_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_THEME_ID=202232136025

# ── Embedded catalogue admin app (`npm run deploy:admin`) ────────────────────
# The admin app runs inside the Shopify admin as a custom app hosted on a
# Cloudflare Worker (admin-app/ — one-time setup in admin-app/SETUP.md).
# It authenticates to the Admin API with the Dev Dashboard app's credentials
# (OAuth client credentials grant, exchanged for a 24h token automatically):
#   1. https://dev.shopify.com → your org → Apps → "Bracelet Catalogue Admin"
#      (create it there if it doesn't exist yet)
#   2. Admin API access scopes: write_products, write_inventory,
#      read_locations, write_publications, write_themes
#   3. Install the app on the store (custom distribution)
#   4. App → Settings → copy the Client ID and Client Secret:
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Admin API version used by the admin app (defaults to 2026-01).
# SHOPIFY_API_VERSION=2026-01
