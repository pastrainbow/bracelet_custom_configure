# Shopify credentials for `npm run deploy:shopify`.
# Copy this file to `.env` (which is gitignored) and fill in the values.
#
# The deploy uses the Shopify CLI with a Theme Access token:
#   1. Install the free "Theme Access" app: https://apps.shopify.com/theme-access
#   2. In it, add a user with your email — Shopify emails you a token (shptka_...)
#   3. Paste that token below as SHOPIFY_ADMIN_TOKEN.
#
# Find SHOPIFY_THEME_ID in the theme editor URL:
#   admin.shopify.com/store/<store>/themes/<THEME_ID>/editor

SHOPIFY_STORE=y4i4ta-hn.myshopify.com
SHOPIFY_ADMIN_TOKEN=shptka_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_THEME_ID=202232136025
