{
  "name": "bracelet-custom-configurator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Custom bracelet builder — embeddable React/Vite widget with realistic bead physics, designed for Shopify integration.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "build:widget": "tsc --noEmit -p tsconfig.json && vite build --mode widget",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.1",
    "lucide-react": "^0.456.0",
    "matter-js": "^0.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/matter-js": "^0.19.7",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "postcss": "^8.4.49",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^8.1.0"
  }
}
